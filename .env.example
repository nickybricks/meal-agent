# LLM providers (only fill in the ones you want to use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth / deploy
ADMIN_EMAIL=
ALLOWED_ORIGINS=
ENV=dev

# LangSmith tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=meal-agent

# Ollama (optional, for local models)
OLLAMA_HOST=http://localhost:11434

# Frontend (Next.js) — set these in frontend/.env.local or the Vercel project
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=
